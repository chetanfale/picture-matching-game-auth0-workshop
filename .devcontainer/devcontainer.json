{
  "name": "Auth0 Token Vault Workshop",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22-bookworm",

  "forwardPorts": [3000],

  "portsAttributes": {
    "3000": {
      "label": "Next.js App",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  },

  // This command runs after the container is created and features are installed
  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "customizations": {
    "vscode": {
      // This is the correct location for VS Code specific settings
      "settings": {
        "corepack.enable": true
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "yzhang.markdown-all-in-one"
      ]
    }
  }
}
