{
  "name": "picture-matching-game-auth0-workshop-root",
  "version": "1.0.0",
  "private": true,
  "description": "Workspace root for the Auth0 AI Agent workshop.",
  "scripts": {
    "dev:app": "pnpm --filter app dev",
    "dev:final": "pnpm --filter final-app dev",
    "dev:emails": "pnpm --filter email-collector dev",
    "deploy:emails": "pnpm --filter email-collector run deploy",
    "setup-auth0": "pnpm --filter app run setup-auth0",
    "setup-auth0:emails": "pnpm --filter email-collector setup-auth0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "1.3.3",
    "typescript": "^5.0.0"
  },
  "engines": {
    "pnpm": ">=8.0.0"
  }
}