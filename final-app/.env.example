# App
APP_BASE_URL=http://localhost:3000

# Auth0
AUTH0_SECRET= # A long secret value used to encrypt the session cookie. Generate one with: openssl rand -hex 32
AUTH0_DOMAIN= # Your Auth0 tenant domain (e.g. your-tenant.us.auth0.com)
AUTH0_CLIENT_ID= # Your Auth0 application client ID
AUTH0_CLIENT_SECRET= # Your Auth0 application client secret

# Google OAuth (optional — for social connection)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
